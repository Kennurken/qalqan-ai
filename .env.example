# Qalqan AI v3.0 — Environment Variables
# Барлығы тегін API кілттер, карта қажет емес

# ===== AI ПРОВАЙДЕРЛЕР =====

# Groq — НЕГІЗГІ AI (14,400 req/day тегін!)
# Тіркелу: https://console.groq.com → API Keys → Create
# Карта: ҚАЖЕТ ЕМЕС
GROQ_API_KEY=

# Gemini — BACKUP AI (250 req/day) + Vision (скриншот)
# Тіркелу: https://aistudio.google.com/apikey → Create API Key
# Карта: ҚАЖЕТ ЕМЕС
GEMINI_API_KEY=

# ===== TELEGRAM =====

# Telegram Bot (апелляциялар мен шағымдар үшін)
# Тіркелу: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== ҚАУІП БАЗАЛАРЫ =====

# PhishTank (фишинг URL базасы)
# Тіркелу: https://phishtank.org/api_register.php
# Карта: ҚАЖЕТ ЕМЕС
PHISHTANK_API_KEY=

# Google Safe Browsing (зиянды URL базасы, 10,000 req/day)
# Тіркелу: https://console.cloud.google.com → APIs → Safe Browsing → Enable → Credentials
# Карта: ҚАЖЕТ ЕМЕС (free tier)
GOOGLE_SAFE_BROWSING_KEY=

# URLhaus — кілт қажет емес (толық тегін)
# OpenPhish — кілт қажет емес (толық тегін)
